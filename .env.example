# Copy this file to .env.local for local development.
# Never commit .env.local to GitHub.

# Zoho SMTP for website inquiries
ZOHO_EMAIL=info@lanchrom.com
ZOHO_APP_PASSWORD=
FROM_EMAIL=info@lanchrom.com
INQUIRY_NOTIFICATION_EMAIL=info@lanchrom.com
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465

# SiteChat widget placeholder
NEXT_PUBLIC_SITECHAT_ENABLED=false
NEXT_PUBLIC_SITECHAT_WIDGET_URL=
NEXT_PUBLIC_SITECHAT_PROJECT_ID=lanchrom
NEXT_PUBLIC_SITECHAT_API_BASE_URL=
NEXT_PUBLIC_SITECHAT_HANDOFF_EMAIL=

# Optional integrations
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
HUBSPOT_PORTAL_ID=
# Preferred: HubSpot Private App access token
HUBSPOT_ACCESS_TOKEN=
# Legacy fallback only
HUBSPOT_API_KEY=
HUBSPOT_USE_CUSTOM_PROPERTIES=true
HUBSPOT_SAMPLE_PIPELINE_ID=default
HUBSPOT_SAMPLE_STAGE_ID=appointmentscheduled
HUBSPOT_QUOTE_PIPELINE_ID=default
HUBSPOT_QUOTE_STAGE_ID=appointmentscheduled
HUBSPOT_OEM_PIPELINE_ID=default
HUBSPOT_OEM_STAGE_ID=appointmentscheduled
RESEND_API_KEY=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_API_TOKEN=
