# Copy this file to .env.local for local development.
# Never commit .env.local to GitHub.

# Zoho SMTP for website inquiries
ZOHO_EMAIL=
ZOHO_APP_PASSWORD=
FROM_EMAIL=
NOTIFICATION_EMAIL=
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465

# SiteChat widget placeholder
NEXT_PUBLIC_SITECHAT_ENABLED=false
NEXT_PUBLIC_SITECHAT_WIDGET_URL=
NEXT_PUBLIC_SITECHAT_PROJECT_ID=lanchrom
NEXT_PUBLIC_SITECHAT_API_BASE_URL=
NEXT_PUBLIC_SITECHAT_HANDOFF_EMAIL=

# Optional integrations
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
HUBSPOT_PORTAL_ID=
HUBSPOT_API_KEY=
RESEND_API_KEY=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_API_TOKEN=
